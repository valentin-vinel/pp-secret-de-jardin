---
---

<header class="header" id="header">
  <nav class="nav container" aria-label="Navigation principale">
    <a href="/" class="nav__brand" aria-label="Secret de Jardin — Accueil">
      <img src="../../public/assets/logo.webp" alt="Secret de Jardin" class="nav__logo" width="140" height="56" />
    </a>
    <button
      class="nav__burger"
      id="burger-btn"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <span class="nav__burger-line"></span>
      <span class="nav__burger-line"></span>
      <span class="nav__burger-line"></span>
    </button>
    <ul class="nav__menu" id="nav-menu">
      <li><a href="#services" class="nav__link">Services</a></li>
      <li><a href="#avis" class="nav__link">Avis clients</a></li>
      <li><a href="#contact" class="nav__link">Contact</a></li>
      <li>
        <a href="tel:0607526848" class="nav__cta">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          06 07 52 68 48
        </a>
      </li>
    </ul>
  </nav>
</header>

<section class="hero" aria-label="Présentation Secret de Jardin">
  <div class="container hero__inner">
    <div class="hero__text">
      <span class="hero__tag">Paysagiste artisan · Rochegude · Drôme Provençale</span>
      <h1 class="hero__title">
        Un extérieur soigné,<br>
        <em>comme vous le méritez</em>
      </h1>
      <p class="hero__subtitle">
        Jardinage, débroussaillage mécanique, dallage et aménagements paysagers réalisés avec soin et savoir-faire depuis plus de 13 ans.
      </p>
      <div class="hero__actions">
        <a href="tel:0607526848" class="btn btn--primary">
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          Appeler maintenant
        </a>
        <a href="#services" class="btn btn--secondary">Voir nos services</a>
      </div>
    </div>
    <div class="hero__visual">
      <div class="hero__carousel" id="hero-carousel" aria-roledescription="carrousel" aria-label="Galerie de réalisations">
        <div class="hero__slides" aria-live="polite">
          <div class="hero__slide hero__slide--active" aria-hidden="false">
            <img
              src="/photo1.webp"
              alt="Jardin aménagé par Secret de Jardin à Rochegude"
              class="hero__img"
              width="800"
              height="600"
            />
          </div>
          <div class="hero__slide" aria-hidden="true">
            <img
              src="/photo2.webp"
              onerror="this.src='/photo1.webp';this.onerror=null;"
              alt="Jardin aménagé par Secret de Jardin à Rochegude"
              class="hero__img"
              width="800"
              height="600"
            />
          </div>
          <div class="hero__slide" aria-hidden="true">
            <img
              src="/photo3.webp"
              onerror="this.src='/photo1.webp';this.onerror=null;"
              alt="Création d'un terrain de pétanque par Secret de Jardin"
              class="hero__img"
              width="800"
              height="600"
            />
          </div>
          <div class="hero__slide" aria-hidden="true">
            <img
              src="/photo4.webp"
              onerror="this.src='/photo1.webp';this.onerror=null;"
              alt="Taillage d'une haie par Secret de Jardin"
              class="hero__img"
              width="800"
              height="600"
            />
          </div>
          <div class="hero__slide" aria-hidden="true">
            <img
              src="/photo5.webp"
              onerror="this.src='/photo1.webp';this.onerror=null;"
              alt="Dallage et aménagement extérieur à Rochegude"
              class="hero__img"
              width="800"
              height="600"
            />
          </div>
        </div>
        <button class="carousel-btn carousel-btn--prev" aria-label="Photo précédente">
          <svg viewBox="0 0 24 24" fill="none" width="20" height="20" aria-hidden="true">
            <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="carousel-btn carousel-btn--next" aria-label="Photo suivante">
          <svg viewBox="0 0 24 24" fill="none" width="20" height="20" aria-hidden="true">
            <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="carousel-dots" role="tablist" aria-label="Navigation dans la galerie">
          <button class="carousel-dot carousel-dot--active" role="tab" aria-label="Photo 1" aria-selected="true"></button>
          <button class="carousel-dot" role="tab" aria-label="Photo 2" aria-selected="false"></button>
          <button class="carousel-dot" role="tab" aria-label="Photo 3" aria-selected="false"></button>
          <button class="carousel-dot" role="tab" aria-label="Photo 4" aria-selected="false"></button>
          <button class="carousel-dot" role="tab" aria-label="Photo 5" aria-selected="false"></button>
        </div>
        <div class="hero__badge">
          <span class="hero__badge-stars" aria-label="Note 5 sur 5">★★★★★</span>
          <span class="hero__badge-text">5/5 · 6 avis Google</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 0;
    background-color: white;
    transition: background-color var(--transition), padding var(--transition), box-shadow var(--transition);
  }

  .header--scrolled {
    background-color: var(--color-white);
    padding: 0.6rem 0;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.25);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .nav__logo {
    height: 65px;
    width: auto;
    object-fit: contain;
  }

  .nav__burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 101;
    min-height: 44px;
    min-width: 44px;
    align-items: center;
    justify-content: center;
  }

  .nav__burger-line {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-primary);
    border-radius: 2px;
    transition: transform var(--transition), opacity var(--transition);
  }

  .nav__burger--open .nav__burger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
    background: var(--color-white);
  }

  .nav__burger--open .nav__burger-line:nth-child(2) {
    opacity: 0;
  }

  .nav__burger--open .nav__burger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
    background: var(--color-white);
  }

  .nav__menu {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--color-primary-dark);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    z-index: 99;
  }

  .nav__menu--open {
    display: flex;
  }

  .nav__link {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-white);
    transition: color var(--transition);
    min-height: 44px;
    display: flex;
    align-items: center;
  }

  .nav__link:hover {
    color: var(--color-accent-light);
  }

  .nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
    padding: 0.75rem 1.5rem;
    background-color: var(--color-accent);
    color: var(--color-white);
    border-radius: var(--radius);
    font-weight: 700;
    font-size: var(--fs-small);
    transition: background-color var(--transition);
  }

  .nav__cta:hover {
    background-color: var(--color-accent-light);
  }

  .hero {
    min-height: 100svh;
    background: linear-gradient(150deg, var(--color-primary-dark) 0%, var(--color-primary) 65%, #4E7A39 100%);
    padding: calc(80px + var(--space-xl)) 0 calc(var(--space-xl) + 80px);
    color: var(--color-white);
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 90px;
    background: var(--color-bg);
    clip-path: polygon(0 100%, 100% 30%, 100% 100%);
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .hero__tag {
    display: inline-block;
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent-light);
    margin-bottom: var(--space-sm);
  }

  .hero__title {
    font-family: var(--font-heading);
    font-size: var(--fs-h1);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-white);
  }

  .hero__title em {
    font-style: italic;
    color: var(--color-accent-light);
  }

  .hero__subtitle {
    font-size: 1.05rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.85);
    max-width: 520px;
    margin: var(--space-sm) auto 0;
    line-height: 1.65;
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    width: 100%;
    margin-top: var(--space-md);
  }

  .hero__actions .btn {
    width: 100%;
  }

  .hero__visual {
    width: 100%;
    max-width: 480px;
    position: relative;
  }

  .hero__carousel {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    aspect-ratio: 4 / 3;
  }

  .hero__slides {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.7s ease;
  }

  .hero__slide--active {
    opacity: 1;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: var(--color-white);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color var(--transition);
    padding: 0;
  }

  .carousel-btn:hover {
    background: rgba(0, 0, 0, 0.55);
  }

  .carousel-btn--prev {
    left: 0.75rem;
  }

  .carousel-btn--next {
    right: 0.75rem;
  }

  .carousel-dots {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.45);
    cursor: pointer;
    padding: 0;
    min-height: unset;
    transition: background-color var(--transition), transform var(--transition);
  }

  .carousel-dot--active {
    background: var(--color-white);
    transform: scale(1.4);
  }

  .hero__badge {
    position: absolute;
    bottom: var(--space-sm);
    left: var(--space-sm);
    background: var(--color-white);
    border-radius: var(--radius);
    padding: 0.5rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 2px;
    box-shadow: var(--shadow);
  }

  .hero__badge-stars {
    color: var(--color-accent);
    font-size: 1rem;
    letter-spacing: 2px;
    line-height: 1;
  }

  .hero__badge-text {
    font-size: var(--fs-xs);
    font-weight: 700;
    color: var(--color-text);
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .hero__actions {
      flex-direction: row;
      justify-content: center;
      width: auto;
    }

    .hero__actions .btn {
      width: auto;
    }

    .nav__logo {
      height: 90px;
      width: auto;
      object-fit: contain;
    }
  }

  @media (min-width: 1024px) {
    .nav__menu {
      display: flex;
      position: static;
      background: none;
      flex-direction: row;
      align-items: center;
      gap: var(--space-md);
      inset: auto;
    }

    .nav__burger {
      display: none;
    }

    .nav__link {
      font-family: var(--font-body);
      font-size: var(--fs-small);
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-primary);
    }

    .hero__inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
      gap: 0;
    }

    .hero__text {
      flex: 0 0 55%;
    }

    .hero__subtitle {
      margin: var(--space-sm) 0 0;
    }

    .hero__actions {
      justify-content: flex-start;
    }

    .hero__visual {
      flex: 0 0 42%;
      max-width: 42%;
    }
  }
</style>
